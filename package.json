{
  "name": "habitxt",
  "version": "1.5.0",
  "description": "Text-based habit tracker — habits as plain Markdown files",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "habitxt": "./dist/index.js",
    "habitxt-server": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest"
  },
  "keywords": [
    "habit",
    "habit-tracker",
    "cli",
    "productivity",
    "markdown",
    "plaintext"
  ],
  "author": "Joern Meyer",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@inquirer/prompts": "^8.4.0",
    "asciichart": "^1.5.25",
    "chalk": "^5.6.2",
    "chrono-node": "^2.9.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.12",
    "smol-toml": "^1.6.1",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
